# ─── Mode ─────────────────────────────────────────────────────────────────────
# DEMO_MODE=true  → skips Ollama entirely; agents use pre-built deterministic
#                   analysis responses. Full pipeline still runs (LangGraph,
#                   tools, mock data, email, resolver). No internet needed.
# DEMO_MODE=false → agents call Ollama for real LLM reasoning (requires Ollama).
DEMO_MODE=true

# ─── LLM (Ollama) ─────────────────────────────────────────────────────────────
# Only used when DEMO_MODE=false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ─── Email Notifications ───────────────────────────────────────────────────────
# Set MOCK_EMAIL=true to log emails to console instead of actually sending them
MOCK_EMAIL=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
ALERT_EMAIL=oncall-team@company.com
